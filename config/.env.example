# Vision Engine — 환경변수 예시
# 이 파일을 복사해 .env 로 만들고 실제 값을 채운다. .env 는 절대 git에 커밋하지 않는다.

# ── Claude (주력) ─────────────────────────────
# Claude Code에서 로그인해 쓰면 별도 키가 필요 없을 수 있음. API 직접 호출 시에만 사용.
ANTHROPIC_API_KEY=

# ── GPT (선택: OpenClaw OAuth를 안 쓰고 API로 붙일 때만) ──
# 참고: GPT Pro 구독 OAuth 방식은 키가 필요 없다. 아래는 API 과금 방식용.
OPENAI_API_KEY=

# ── 보조 무료 API (선택) ──────────────────────
# Google AI Studio (Gemini)
GEMINI_API_KEY=
# GitHub Models (GitHub 계정 토큰)
GITHUB_TOKEN=
# NVIDIA API (build.nvidia.com)
NVIDIA_API_KEY=

# ── 로컬 (선택) ───────────────────────────────
# Ollama는 로컬 실행이라 키 불필요. 엔드포인트만 필요시 지정.
OLLAMA_HOST=http://127.0.0.1:11434
